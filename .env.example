# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://docflow:CHANGE_ME@postgres:5432/docflow?schema=public

# ── NextAuth ───────────────────────────────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://yourdomain.com

# ── Super-admin account (upserted on every boot) ──────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_NAME=Super Admin
ADMIN_PASSWORD=CHANGE_ME_strong_password

# ── Encryption key for secrets-at-rest (AES-256-GCM) ─────────
# Must be 32+ random characters
APP_ENCRYPTION_KEY=generate-with-openssl-rand-base64-32

# ── Optional: set after configuring via /admin ────────────────
# (These are stored encrypted in the DB; listed here for reference only)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# OPENAI_API_KEY=sk-...
# STRIPE_SECRET_KEY=sk_live_...
