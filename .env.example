# ─────────────────────────────────────────────────────────────
# DocFlow Pro — Environment Variables
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────

# ── NextAuth ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-key-change-this-in-production

# Your app URL (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# ── Super Admin Credentials ───────────────────────────────────
ADMIN_EMAIL=admin@docflow.pro
ADMIN_NAME=Super Admin

# Option A: Plain password (dev only — never use in production)
ADMIN_PASSWORD=Admin@DocFlow2024!

# Option B: Bcrypt hash (recommended for production)
# Generate with: node -e "const b=require('bcryptjs');b.hash('yourpassword',12).then(console.log)"
# ADMIN_PASSWORD_HASH=$2a$12$...

# ── App Config ────────────────────────────────────────────────
NODE_ENV=production

# ── Optional: Email (future feature) ─────────────────────────
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxx
# EMAIL_FROM=noreply@docflow.pro
