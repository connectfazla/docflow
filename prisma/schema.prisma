// DocFlow Pro — Prisma schema
// Postgres: local docker / Vercel Postgres / any pg 14+

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────── Auth / Users ────────────────────────────

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum PlanTier {
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  plan         PlanTier @default(STARTER)
  company      String?
  avatarUrl    String?
  emailVerified DateTime?
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  documents    Document[]
  templates    Template[]   @relation("TemplateAuthor")
  auditLogs    AuditLog[]
  subscription Subscription?

  @@index([email])
}

// ──────────────────────────── Documents ────────────────────────────

enum DocumentStatus {
  DRAFT
  SENT
  VIEWED
  SIGNED
  COMPLETED
  DECLINED
  EXPIRED
}

model Document {
  id           String          @id @default(cuid())
  title        String
  content      String          @default("") // HTML from Tiptap
  status       DocumentStatus  @default(DRAFT)
  ownerId      String
  owner        User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  templateId   String?
  template     Template?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  tags         String[]        @default([])
  shareToken   String?         @unique
  sharePublic  Boolean         @default(false)
  expiresAt    DateTime?
  sentAt       DateTime?
  completedAt  DateTime?
  viewCount    Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  recipients   Recipient[]
  activity     ActivityItem[]

  @@index([ownerId])
  @@index([status])
  @@index([shareToken])
}

enum RecipientRole {
  SIGNER
  VIEWER
  APPROVER
}

enum RecipientStatus {
  PENDING
  VIEWED
  SIGNED
  DECLINED
}

model Recipient {
  id         String          @id @default(cuid())
  documentId String
  document   Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  name       String
  email      String
  role       RecipientRole   @default(SIGNER)
  status     RecipientStatus @default(PENDING)
  order      Int             @default(0)
  signedAt   DateTime?
  signature  String?         // data URL of drawn signature
  ipAddress  String?
  createdAt  DateTime        @default(now())

  @@index([documentId])
  @@index([email])
}

// ──────────────────────────── Templates ────────────────────────────

model Template {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  content     String   @default("") // HTML
  tags        String[] @default([])
  thumbnail   String?
  usageCount  Int      @default(0)
  isLocked    Boolean  @default(false)
  isPublic    Boolean  @default(true)
  authorId    String?
  author      User?    @relation("TemplateAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents   Document[]

  @@index([category])
}

// ──────────────────────────── Activity Log ────────────────────────────

enum ActivityType {
  CREATED
  SENT
  VIEWED
  SIGNED
  COMMENTED
  DECLINED
  COMPLETED
}

model ActivityItem {
  id           String       @id @default(cuid())
  documentId   String
  document     Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  type         ActivityType
  actorName    String
  actorEmail   String?
  metadata     Json?
  createdAt    DateTime     @default(now())

  @@index([documentId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  target    String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ──────────────────────────── Settings (admin) ────────────────────────────
// Single-row key-value store for admin configuration.
// Values are encrypted at rest (see src/lib/crypto.ts).

model AppSetting {
  key       String   @id
  value     String   // encrypted payload
  isSecret  Boolean  @default(false)
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// ──────────────────────────── Plans & Billing ────────────────────────────

model Plan {
  id              String   @id @default(cuid())
  slug            String   @unique // "starter" | "pro" | "business"
  name            String
  description     String
  priceMonthly    Int      @default(0) // cents
  priceYearly     Int      @default(0) // cents
  currency        String   @default("USD")
  features        String[] @default([])
  docLimit        Int      @default(5)     // -1 = unlimited
  teamLimit       Int      @default(1)
  aiEnabled       Boolean  @default(false)
  isActive        Boolean  @default(true)
  isPopular       Boolean  @default(false)
  sortOrder       Int      @default(0)
  stripePriceId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscriptions   Subscription[]
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum PaymentProvider {
  FREE
  STRIPE
  ZIINA
}

model Subscription {
  id                    String             @id @default(cuid())
  userId                String             @unique
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId                String
  plan                  Plan               @relation(fields: [planId], references: [id])
  status                SubscriptionStatus @default(ACTIVE)
  provider              PaymentProvider    @default(FREE)
  providerCustomerId    String?
  providerSubscriptionId String?
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
}
